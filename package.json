    "@babel/node": "^7.10.4",
    "@babel/preset-env": "^7.10.4",
    "nodemon": "^2.0.20",
    "prettier": "^2.0.5",
    "pretty-quick": "^2.0.1"
  },
  "dependencies": {
    "apicache": "^1.6.2",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "mongodb": "^3.5.9",
    "redis": "^3.1.2"
  }
}
